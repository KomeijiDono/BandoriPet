{
  "name": "bandori-desktop-pet",
  "version": "2.1.3",
  "description": "Bandori Desktop Pet ~Voice Append~",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "bandori.pet.append",
    "productName": "BandoriPet Voice Append",
    "copyright": "Copyright © 2026 KomeijiDono & 千早ですわ",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!model/**/*",
      "!physics_items/**/*"
    ],
    "win": {
      "target": "dir",
      "icon": "icon.ico"
    },
    "asar": false
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "@coooookies/windows-smtc-monitor-win32-x64-msvc": "^1.0.12",
    "matter-js": "^0.20.0",
    "pixi.js": "^6.5.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "rcedit": "^5.0.1"
  },
  "author": {
    "name": "KomeijiDono",
    "email": "564449138@qq.com",
    "url": "https://github.com/KomeijiDono"
  },
  "contributors": [
    {
      "name": "千早ですわ",
      "email": "827677473@qq.com",
      "url": "https://github.com/Anokianx"
    }
  ]
